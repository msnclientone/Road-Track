generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String?
  phone              String?
  name               String?
  role               UserRole       @default(CUSTOMER)
  partnerStatus      PartnerStatus?
  emailVerifiedAt    DateTime?
  termsAcceptedAt    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  mustChangePassword Boolean        @default(false)
  resortOwnerId      String?        @unique
  vehicleOwnerId     String?        @unique
  auditLogs          AuditLog[]
  blogPosts          BlogPost[]
  buckets            Bucket[]
  enquiries          Enquiry[]
  guideProfile       Guide?
  notifications      Notification[]
  resorts            Resort[]
  reviews            Review[]
  vehicles           Vehicle[]

  @@index([role])
  @@index([partnerStatus])
  @@index([vehicleOwnerId])
  @@index([resortOwnerId])
}

model OtpCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Destination {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String
  bestTimeToVisit String?
  heroImageUrl    String?
  latitude        Float?
  longitude       Float?
  estTripCostMin  Int?
  estTripCostMax  Int?
  seoTitle        String?
  seoDescription  String?
  published       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  googleMapsLink  String?
  media           DestinationMedia[]
  enquiries       Enquiry[]
  nearbyPlaces    NearbyPlace[]      @relation("DestinationNearby")
  nearbyTo        NearbyPlace[]      @relation("NearbyDestination")
  packages        Package[]
  resorts         Resort[]
  vehicles        Vehicle[]
}

model DestinationMedia {
  id            String      @id @default(cuid())
  destinationId String
  url           String
  type          MediaKind
  order         Int         @default(0)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
}

model Resort {
  id                  String        @id @default(cuid())
  ownerId             String?
  destinationId       String
  name                String
  slug                String        @unique
  description         String
  address             String?
  latitude            Float?
  longitude           Float?
  priceMin            Int
  priceMax            Int
  amenities           Json
  status              PartnerStatus @default(PENDING)
  soldOut             Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  availableAcRooms    Int           @default(0)
  availableNonAcRooms Int           @default(0)
  googleMapsLink      String?
  bookings            Booking[]
  bucketItems         BucketItem[]
  enquiries           Enquiry[]
  destination         Destination   @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  owner               User?         @relation(fields: [ownerId], references: [id])
  media               ResortMedia[]
  reviews             Review[]
  rooms               RoomType[]
  tripBookings        TripBooking[] @relation("ResortTripBookings")

  @@index([destinationId, status])
  @@index([ownerId])
}

model RoomType {
  id            String             @id @default(cuid())
  resortId      String
  name          String
  pricePerNight Int
  maxOccupancy  Int
  availability  AvailabilityStatus @default(AVAILABLE)
  resort        Resort             @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@index([resortId])
}

model ResortMedia {
  id       String    @id @default(cuid())
  resortId String
  url      String
  type     MediaKind
  order    Int       @default(0)
  resort   Resort    @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@index([resortId])
}

model Vehicle {
  id                String             @id @default(cuid())
  ownerId           String?
  destinationId     String?
  vehicleType       String
  registrationNo    String?
  seatingCapacity   Int
  driverName        String
  driverPhone       String
  pricePerDay       Int?
  pricePerKm        Int?
  status            PartnerStatus      @default(PENDING)
  availability      AvailabilityStatus @default(AVAILABLE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  ownerCanEditPrice Boolean            @default(false)
  minimumKm         Int?
  minimumPrice      Int?
  bookedUntil       DateTime?
  heroImageUrl      String?
  bookings          Booking[]
  bucketItems       BucketItem[]
  enquiries         Enquiry[]
  reviews           Review[]
  tripBookings      TripBooking[]      @relation("VehicleTripBookings")
  destination       Destination?       @relation(fields: [destinationId], references: [id])
  owner             User?              @relation(fields: [ownerId], references: [id])
  media             VehicleMedia[]

  @@index([destinationId, status])
  @@index([ownerId])
  @@index([availability])
}

model VehicleMedia {
  id        String  @id @default(cuid())
  vehicleId String
  url       String
  order     Int     @default(0)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Package {
  id            String      @id @default(cuid())
  destinationId String
  title         String
  slug          String      @unique
  durationDays  Int
  basePrice     Int
  inclusions    Json
  customizable  Json
  published     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId, published])
}

model Enquiry {
  id                String        @id @default(cuid())
  customerId        String?
  customerName      String
  customerPhone     String
  customerEmail     String?
  destinationId     String?
  travelDate        DateTime?
  numPeople         Int?
  vehicleRequired   Boolean       @default(false)
  resortRequired    Boolean       @default(false)
  message           String?
  source            EnquirySource @default(WEBSITE)
  status            LeadStatus    @default(NEW)
  assignedResortId  String?
  assignedVehicleId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  enquiryId         String?       @unique
  bookings          Booking[]
  assignedResort    Resort?       @relation(fields: [assignedResortId], references: [id])
  assignedVehicle   Vehicle?      @relation(fields: [assignedVehicleId], references: [id])
  customer          User?         @relation(fields: [customerId], references: [id])
  destination       Destination?  @relation(fields: [destinationId], references: [id])
  tripBooking       TripBooking?

  @@index([status, createdAt])
  @@index([customerPhone])
  @@index([destinationId])
  @@index([assignedResortId])
  @@index([assignedVehicleId])
}

model Booking {
  id            String        @id @default(cuid())
  enquiryId     String
  resortId      String?
  vehicleId     String?
  bookingValue  Int
  commissionPct Float
  commissionAmt Int
  payoutAmt     Int
  status        BookingStatus @default(CONFIRMED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  enquiry       Enquiry       @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  resort        Resort?       @relation(fields: [resortId], references: [id])
  vehicle       Vehicle?      @relation(fields: [vehicleId], references: [id])

  @@index([enquiryId])
  @@index([resortId])
  @@index([vehicleId])
}

model Bucket {
  id         String       @id @default(cuid())
  customerId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  customer   User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      BucketItem[]

  @@index([customerId])
}

model BucketItem {
  id        String   @id @default(cuid())
  bucketId  String
  resortId  String?
  vehicleId String?
  quantity  Int      @default(1)
  bucket    Bucket   @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  resort    Resort?  @relation(fields: [resortId], references: [id])
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([bucketId])
}

model Review {
  id         String   @id @default(cuid())
  customerId String
  targetType String
  resortId   String?
  vehicleId  String?
  rating     Int
  comment    String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  resort     Resort?  @relation(fields: [resortId], references: [id], onDelete: Cascade)
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([resortId])
  @@index([vehicleId])
  @@index([approved])
}

model Guide {
  id         String   @id @default(cuid())
  userId     String   @unique
  type       String
  bio        String?
  ratePerDay Int?
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id             String    @id @default(cuid())
  authorId       String
  title          String
  slug           String    @unique
  content        String
  featuredImage  String?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  author         User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([publishedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model CommissionRule {
  id          String   @id @default(cuid())
  appliesTo   String
  percentage  Float
  effectiveAt DateTime @default(now())

  @@index([appliesTo, effectiveAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model TripBooking {
  id                 String            @id @default(cuid())
  bookingId          String            @unique
  customerName       String
  customerPhone      String
  destinationName    String?
  checkIn            DateTime?
  checkOut           DateTime?
  numDays            Int?
  numNights          Int?
  numPeople          Int?
  selectedResortId   String?
  selectedVehicleId  String?
  vehicleRegNo       String?
  vehicleOwnerId     String?
  resortOwnerId      String?
  pricingMode        String?
  distance           String?
  roomType           String?
  vehicleCost        Int?
  resortCost         Int?
  totalCost          Int?
  perHeadCost        Int?
  status             TripBookingStatus @default(NEW)
  enquiryId          String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  inventoryRestored  Boolean           @default(false)
  inventoryUpdated   Boolean           @default(false)
  acRoomsRequired    Int               @default(1)
  nonAcRoomsRequired Int               @default(0)
  enquiry            Enquiry?          @relation(fields: [enquiryId], references: [id])
  selectedResort     Resort?           @relation("ResortTripBookings", fields: [selectedResortId], references: [id])
  selectedVehicle    Vehicle?          @relation("VehicleTripBookings", fields: [selectedVehicleId], references: [id])

  @@index([bookingId])
  @@index([status, createdAt])
  @@index([customerPhone])
  @@index([selectedResortId])
  @@index([selectedVehicleId])
  @@index([enquiryId])
}

model NearbyPlace {
  id                  String      @id @default(cuid())
  destinationId       String
  nearbyDestinationId String
  distanceKm          Int
  createdAt           DateTime    @default(now())
  destination         Destination @relation("DestinationNearby", fields: [destinationId], references: [id], onDelete: Cascade)
  nearbyDestination   Destination @relation("NearbyDestination", fields: [nearbyDestinationId], references: [id], onDelete: Cascade)
}

enum TripBookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  RESORT_OWNER
  VEHICLE_OWNER
  GUIDE
  CUSTOMER
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  CONFIRMED
  CANCELLED
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  SOLD_OUT
}

enum MediaKind {
  PHOTO
  VIDEO
}

enum EnquirySource {
  WEBSITE
  WHATSAPP
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
